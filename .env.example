# Accelance AI Platform — Root Environment Variables
#
# This file documents top-level env vars. The actual app config lives in:
#   packages/server/.env  (copy from packages/server/.env.example)
#
# This root file is kept for tooling that reads from the project root.
# .env files are gitignored — never commit real credentials.

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Direct connection host (not pooler) — required for TypeORM migrations.
# Get a free account at https://neon.tech
DATABASE_TYPE=postgres
DATABASE_HOST=your-project.c-9.us-east-1.aws.neon.tech
DATABASE_PORT=5432
DATABASE_USER=neondb_owner
DATABASE_PASSWORD=your_neon_password
DATABASE_NAME=neondb
DATABASE_SSL=true

# ── Auth secrets ──────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_AUTH_TOKEN_SECRET=replace_with_64_byte_hex
JWT_REFRESH_TOKEN_SECRET=replace_with_different_64_byte_hex
EXPRESS_SESSION_SECRET=replace_with_strong_random_string

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
# Optional — without SMTP, invite URLs are logged to console instead of emailed.
# Note: Flowise reads SMTP_PASSWORD (not SMTP_PASS) and SENDER_EMAIL (not SMTP_FROM).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASSWORD=your_brevo_smtp_password
SENDER_EMAIL=noreply@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3002
APP_URL=http://localhost:3002
FLOWISE_PLATFORM=enterprise
